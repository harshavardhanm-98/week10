#include <stdio.h>
#include <stdlib.h>
int main() {
    int *ptr;
    int n1, n2, i;
    printf("Enter initial number of elements: ");
    scanf("%d", &n1);
    ptr = (int*)malloc(n1 * sizeof(int));
    if (ptr == NULL) {
        printf("Memory not allocated. Exiting...\n");
        exit(0);
    }
    printf("Enter %d elements:\n", n1);
    for (i = 0; i < n1; ++i) {
        scanf("%d", &ptr[i]);
    }
    printf("\nEnter the new size of the array: ");
    scanf("%d", &n2);
    ptr = (int*)realloc(ptr, n2 * sizeof(int));
    printf("Memory successfully re-allocated.\n");
    if (n2 > n1) {
        printf("Enter %d additional elements:\n", n2 - n1);
        for (i = n1; i < n2; ++i) {
            scanf("%d", &ptr[i]);
        }
    }
    printf("\nThe elements in the array are:\n");
    for (i = 0; i < n2; ++i) {
        printf("%d ", ptr[i]);
    }
    free(ptr);
    printf("\n\nMemory successfully freed.\n");
    printf("\nREG NO:25331A05I5");
    return 0;
}
